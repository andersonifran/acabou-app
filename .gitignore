# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# config local do Claude Code (não versionar)
.claude/

# assets de trabalho / vídeos brutos guardados na pasta (não versionar)
/public/Video*.mp4
/public/video-source*.mp4

# scripts utilitários locais (caminhos absolutos) — exceto o guard de build,
# que PRECISA ser versionado (roda no build da Vercel pra blindar o SW).
/scripts/*
!/scripts/check-sw-rsc.mjs
!/scripts/check-theme-flash.mjs
!/scripts/check-secrets.mjs

# Arquivos de trabalho do Play Console (exports/CSV do Data Safety) — só local
/play-console/

# gerador de screenshots de marketing (arquivo local pesado, não deve ir pra produção)
/public/marketing/

# kit bruto do Mercado Pago (extraído do zip) — usamos só /public/mercadopago/
/public/logos mercado pago/
